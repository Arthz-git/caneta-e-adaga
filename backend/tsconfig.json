{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"rootDir": "src",
		"outDir": "dist",
		"types": ["node"],
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true
	},
	"include": ["src"]
}
